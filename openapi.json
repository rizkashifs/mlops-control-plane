        ],
        "title": "PromoteRequest"
      },
      "RegisterRequest": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "version": {
            "type": "string",
            "title": "Version"
          },
          "owner": {
            "type": "string",
            "title": "Owner"
          },
          "artifact_uri": {
            "type": "string",
            "title": "Artifact Uri"
          },
          "experiment_id": {
            "type": "string",
            "title": "Experiment Id"
          },
          "dataset_version": {
            "type": "string",
            "title": "Dataset Version"
          },
