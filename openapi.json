          },
          "tags": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object",
            "title": "Tags",
            "default": {}
          }
        },
        "type": "object",
        "required": [
          "name",
          "version",
          "owner",
          "artifact_uri",
          "experiment_id",
          "dataset_version"
        ],
        "title": "RegisterRequest"
      },
      "RejectRequest": {
        "properties": {
          "stage": {
            "$ref": "#/components/schemas/ApprovalStage"
          },
          "reviewer": {
            "type": "string",
            "title": "Reviewer"
          },
          "notes": {
