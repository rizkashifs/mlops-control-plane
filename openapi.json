      },
      "ApproveRequest": {
        "properties": {
          "stage": {
            "$ref": "#/components/schemas/ApprovalStage"
          },
          "reviewer": {
            "type": "string",
            "title": "Reviewer"
          },
          "notes": {
            "type": "string",
            "title": "Notes",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "stage",
          "reviewer"
        ],
        "title": "ApproveRequest"
      },
      "EvidenceItem": {
        "properties": {
          "metric_name": {
            "type": "string",
            "title": "Metric Name"
          },
          "metric_value": {
            "type": "number",
            "title": "Metric Value"
          },
          "passed": {
            "type": "boolean",
            "title": "Passed"
          },
          "notes": {
            "type": "string",
            "title": "Notes",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "metric_name",
          "metric_value",
          "passed"
        ],
        "title": "EvidenceItem"
